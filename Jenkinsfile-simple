pipeline {
    agent {
        kubernetes {
            label 'gemd-agent-pod'
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                  containers:
                  - name: gemd
                    image: ghcr.io/generalpepperoni/gemd-core:latest
                    tty: true
                  - name: helm
                    image: alpine/helm:3.12.3
                    command: ["/bin/sh", "-c"]
                    args: ["sleep infinity"]
                    tty: true
                  - name: kubectl
                    image: bitnami/kubectl:1.27.4
                    command: ["/bin/sh", "-c"]
                    args: ["sleep infinity"]
                    tty: true
                '''
        }
    }
    stages {
        stage('Build Application') {
            steps {
                container('gemd') {
                    sh 'bash -lc "rosrun gem_pure_pursuit_sim pure_pursuit_sim.py"'
                }
            }
        }
    }
}
